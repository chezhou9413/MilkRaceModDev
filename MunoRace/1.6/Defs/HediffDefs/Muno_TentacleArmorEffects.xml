<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <HediffDef>
    <defName>Muno_TentacleNervePassive</defName>
    <label>活化触手神经</label>
    <description>活体触手组织持续强化神经传导，操作能力 +20%，视觉能力 +15%，每小时消耗 4 点乳源质。</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>false</isBad>
    <defaultLabelColor>(0.75, 0.55, 0.95)</defaultLabelColor>
    <stages>
      <li>
        <capMods>
          <li>
            <capacity>Manipulation</capacity>
            <offset>0.2</offset>
          </li>
          <li>
            <capacity>Sight</capacity>
            <offset>0.15</offset>
          </li>
        </capMods>
      </li>
    </stages>
    <comps>
      <li Class="Verse.HediffCompProperties_RemoveIfApparelDropped" />
      <li Class="MunoRaceLib.MunoComp.HediffCompProperties_GalactogenDrain">
        <drainPerHour>4</drainPerHour>
      </li>
    </comps>
  </HediffDef>

  <HediffDef>
    <defName>Muno_TentacleBioLiningActive</defName>
    <label>激活生物内衬</label>
    <description>主动激活生物内衬后，提高利器、钝器防护各 30%，心情 +12，意识 +10%。消耗 1 个乳源质浓浆，持续 4 小时。</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>false</isBad>
    <defaultLabelColor>(0.95, 0.55, 0.75)</defaultLabelColor>
    <stages>
      <li>
        <statFactors>
          <ArmorRating_Sharp>1.3</ArmorRating_Sharp>
          <ArmorRating_Blunt>1.3</ArmorRating_Blunt>
        </statFactors>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>0.1</offset>
          </li>
        </capMods>
      </li>
    </stages>
    <comps>
      <li Class="Verse.HediffCompProperties_Disappears">
        <disappearsAfterTicks>60000</disappearsAfterTicks>
      </li>
      <li Class="MunoRaceLib.MunoComp.HediffCompProperties_TentacleArmorMemory">
        <thoughtDef>Muno_TentacleBioLiningPleasure</thoughtDef>
      </li>
    </comps>
  </HediffDef>

  <HediffDef>
    <defName>Muno_TentacleNerveActive</defName>
    <label>活化触手神经(狂乱)</label>
    <description>狂乱触手甲持续强化神经系统，提高操作能力 +45%、视觉能力 +40%，每小时消耗 4 点乳源质。</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>false</isBad>
    <defaultLabelColor>(0.9, 0.25, 0.6)</defaultLabelColor>
    <stages>
      <li>
        <capMods>
          <li>
            <capacity>Manipulation</capacity>
            <offset>0.45</offset>
          </li>
          <li>
            <capacity>Sight</capacity>
            <offset>0.4</offset>
          </li>
        </capMods>
      </li>
    </stages>
    <comps>
      <li Class="Verse.HediffCompProperties_RemoveIfApparelDropped" />
      <li Class="MunoRaceLib.MunoComp.HediffCompProperties_GalactogenDrain">
        <drainPerHour>4</drainPerHour>
      </li>
    </comps>
  </HediffDef>

  <HediffDef>
    <defName>Muno_TentacleBioLiningPassive</defName>
    <label>激活生物内衬(失控)</label>
    <description>主动激活狂乱触手甲的生物内衬后，提高利器、钝器防护各 40%，心情 +18，意识 +15%。消耗 1 个乳源质浓浆，持续 4 小时。</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>false</isBad>
    <defaultLabelColor>(1.0, 0.3, 0.5)</defaultLabelColor>
    <stages>
      <li>
        <statFactors>
          <ArmorRating_Sharp>1.4</ArmorRating_Sharp>
          <ArmorRating_Blunt>1.4</ArmorRating_Blunt>
        </statFactors>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>0.15</offset>
          </li>
        </capMods>
      </li>
    </stages>
    <comps>
      <li Class="Verse.HediffCompProperties_Disappears">
        <disappearsAfterTicks>60000</disappearsAfterTicks>
      </li>
      <li Class="MunoRaceLib.MunoComp.HediffCompProperties_TentacleArmorMemory">
        <thoughtDef>Muno_TentacleBioLiningPleasureStrong</thoughtDef>
      </li>
    </comps>
  </HediffDef>

  <HediffDef>
    <defName>Muno_TentacleMinionLifetime</defName>
    <label>次级个体维持</label>
    <description>该次级个体由触手甲短暂维持，时间结束后会自行崩解。</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>false</isBad>
    <comps>
      <li Class="Verse.HediffCompProperties_Disappears">
        <disappearsAfterTicks>90000</disappearsAfterTicks>
      </li>
      <li Class="MunoRaceLib.MunoComp.HediffCompProperties_TentacleMinionLifetime" />
    </comps>
  </HediffDef>

  <HediffDef>
    <defName>Muno_TentacleWithdrawal</defName>
    <label>失控触手甲戒断</label>
    <description>在产生依赖后强行脱下失控触手甲，导致精神与意识遭到剧烈反噬。</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>true</isBad>
    <defaultLabelColor>(0.9, 0.2, 0.2)</defaultLabelColor>
    <stages>
      <li>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <postFactor>0.5</postFactor>
          </li>
        </capMods>
      </li>
    </stages>
    <comps>
      <li Class="MunoRaceLib.MunoComp.HediffCompProperties_TentacleArmorMemory">
        <thoughtDef>Muno_TentacleWithdrawalThought</thoughtDef>
      </li>
      <li Class="MunoRaceLib.MunoComp.HediffCompProperties_ForceEnhancement">
        <minimumSeverity>4</minimumSeverity>
      </li>
    </comps>
  </HediffDef>

</Defs>
