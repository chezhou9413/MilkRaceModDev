    <description>分子料理带来的短期不良反应，意识降低 10%。</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>true</isBad>
    <defaultLabelColor>(0.9, 0.25, 0.25)</defaultLabelColor>
    <stages>
      <li>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>-0.1</offset>
          </li>
        </capMods>
      </li>
    </stages>
    <comps>
      <li Class="Verse.HediffCompProperties_Disappears">
        <disappearsAfterTicks>300000</disappearsAfterTicks>
        <showRemainingTime>true</showRemainingTime>
      </li>
    </comps>
  </HediffDef>

  <HediffDef>
    <defName>Muno_MolecularCuisineConsciousnessPermanent</defName>
    <label>分子料理永久性神经活化</label>
    <description>分子料理极低概率诱发的永久性神经活化，意识提高 15%。</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>false</isBad>
    <defaultLabelColor>(0.92, 0.82, 0.55)</defaultLabelColor>
    <stages>
      <li>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>0.15</offset>
          </li>
        </capMods>
      </li>
    </stages>
