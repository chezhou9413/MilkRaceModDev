<?xml version="1.0" encoding="utf-8" ?>
<Defs>

    <RoyalTitleDef Abstract="True" Name="BaseMunoTitle" >
    <tags>
      <li>Muno_Title</li>
    </tags>
    <awardThought>GainedTitle</awardThought>
    <lostThought>LostTitle</lostThought>
    <canBeInherited>false</canBeInherited>
    </RoyalTitleDef>

    <RoyalTitleDef ParentName="BaseMunoTitle">
    <defName>Muno_JuniorAssistant</defName>
    <label>初级协助者</label>
    <description>在边缘世界与缪诺进行一些简单协助工作的人会获得这头衔.</description>
    <seniority>0</seniority>
    <favorCost>1</favorCost>
    <changeHeirQuestPoints>1000</changeHeirQuestPoints>
    <allowDignifiedMeditationFocus>False</allowDignifiedMeditationFocus>
    <awardWorkerClass>RoyalTitleAwardWorker_Instant</awardWorkerClass>
    </RoyalTitleDef>

    <RoyalTitleDef ParentName="BaseMunoTitle">
    <defName>Muno_Assistant</defName>
    <label>协助者</label>
    <description>在证明了自身存在价值后，更进一步协助缪诺们执行各种任务后，会获得这头衔.</description>
    <seniority>10</seniority>
    <favorCost>5</favorCost>
    <changeHeirQuestPoints>1000</changeHeirQuestPoints>
    <allowDignifiedMeditationFocus>False</allowDignifiedMeditationFocus>
    <awardWorkerClass>RoyalTitleAwardWorker_Instant</awardWorkerClass>
    <permitPointsAwarded>1</permitPointsAwarded>
    </RoyalTitleDef>

    <RoyalTitleDef ParentName="BaseMunoTitle">
    <defName>Muno_SeniorAssistant</defName>
    <label>高级协助者</label>
    <description>进行了一系列协助工作，取得缪诺们的初步信任后，会获得这头衔.</description>
    <seniority>50</seniority>
    <favorCost>10</favorCost>
    <changeHeirQuestPoints>1000</changeHeirQuestPoints>
    <permitPointsAwarded>1</permitPointsAwarded>
    <commonality>1</commonality>
  </RoyalTitleDef>

</Defs>